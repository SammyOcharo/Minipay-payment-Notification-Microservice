{
  "info": {
    "name": "MiniPay API Collection",
    "description": "Complete API collection for MiniPay Payment & Notification Microservice",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "gateway_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "payment_url",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var response = pm.response.json();",
                  "if (response.accessToken) {",
                  "    pm.collectionVariables.set('token', response.accessToken);",
                  "    console.log('Token saved:', response.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"john@minipay.com\",\n  \"password\": \"password123\",\n  \"phoneNumber\": \"+254712345678\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/auth/register",
              "host": ["{{gateway_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new user. Automatically saves JWT token to collection variable."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var response = pm.response.json();",
                  "if (response.accessToken) {",
                  "    pm.collectionVariables.set('token', response.accessToken);",
                  "    console.log('Token saved:', response.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@minipay.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/auth/login",
              "host": ["{{gateway_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login and get JWT token. Token is automatically saved."
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Initiate MPESA Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{$guid}}",
                "description": "Unique key to prevent duplicate payments"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100.00,\n  \"currency\": \"KES\",\n  \"phoneNumber\": \"+254712345678\",\n  \"paymentMethod\": \"MPESA\",\n  \"description\": \"Test MPESA payment\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/payments",
              "host": ["{{gateway_url}}"],
              "path": ["api", "payments"]
            },
            "description": "Initiate M-PESA STK Push payment. Requires Idempotency-Key header to prevent double charges."
          }
        },
        {
          "name": "Initiate Card Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{$guid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 500.00,\n  \"currency\": \"KES\",\n  \"phoneNumber\": \"+254712345678\",\n  \"paymentMethod\": \"CARD\",\n  \"description\": \"Test card payment\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/payments",
              "host": ["{{gateway_url}}"],
              "path": ["api", "payments"]
            },
            "description": "Initiate card payment simulation."
          }
        },
        {
          "name": "Initiate Payment - Idempotency Test",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Idempotency-Key",
                "value": "test-idempotency-key-fixed-123",
                "description": "Fixed key - send twice to test idempotency"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100.00,\n  \"currency\": \"KES\",\n  \"phoneNumber\": \"+254712345678\",\n  \"paymentMethod\": \"MPESA\",\n  \"description\": \"Idempotency test\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/payments",
              "host": ["{{gateway_url}}"],
              "path": ["api", "payments"]
            },
            "description": "Send this request TWICE with the same Idempotency-Key to prove no double charge occurs."
          }
        },
        {
          "name": "Get Payment by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{gateway_url}}/api/payments/:id",
              "host": ["{{gateway_url}}"],
              "path": ["api", "payments", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "your-payment-id-here",
                  "description": "Payment UUID from initiate payment response"
                }
              ]
            },
            "description": "Get payment details by ID."
          }
        },
        {
          "name": "Get Payment History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{gateway_url}}/api/payments?page=0&size=10&sort=createdAt,desc",
              "host": ["{{gateway_url}}"],
              "path": ["api", "payments"],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "sort",
                  "value": "createdAt,desc"
                }
              ]
            },
            "description": "Get paginated payment history for the authenticated user."
          }
        },
        {
          "name": "M-PESA Callback Simulation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Body\": {\n    \"stkCallback\": {\n      \"MerchantRequestID\": \"test-merchant-id\",\n      \"CheckoutRequestID\": \"ws_CO_YOUR_CHECKOUT_ID\",\n      \"ResultCode\": 0,\n      \"ResultDesc\": \"The service request is processed successfully.\",\n      \"CallbackMetadata\": {\n        \"Item\": [\n          {\"Name\": \"Amount\", \"Value\": 100.00},\n          {\"Name\": \"MpesaReceiptNumber\", \"Value\": \"OEI2AK4RI0\"},\n          {\"Name\": \"TransactionDate\", \"Value\": 20241221143000},\n          {\"Name\": \"PhoneNumber\", \"Value\": 254712345678}\n        ]\n      }\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{payment_url}}/api/payments/mpesa/callback",
              "host": ["{{payment_url}}"],
              "path": ["api", "payments", "mpesa", "callback"]
            },
            "description": "Simulate M-PESA callback from Safaricom. Replace CheckoutRequestID with real ID from payment response."
          }
        }
      ]
    },
    {
      "name": "Health Checks",
      "item": [
        {
          "name": "Gateway Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gateway_url}}/actuator/health",
              "host": ["{{gateway_url}}"],
              "path": ["actuator", "health"]
            }
          }
        },
        {
          "name": "Payment Service Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{payment_url}}/actuator/health",
              "host": ["{{payment_url}}"],
              "path": ["actuator", "health"]
            }
          }
        },
        {
          "name": "Circuit Breakers Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{payment_url}}/actuator/health",
              "host": ["{{payment_url}}"],
              "path": ["actuator", "health"]
            },
            "description": "Shows circuit breaker status for mpesa-gateway and card-gateway"
          }
        }
      ]
    }
  ]
}